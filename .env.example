# --- Backend (Python) ---
DEBUG=false
PUBLIC_BASE_URL=https://traveltech-backend.onrender.com

# Database (SQLite default; PostgreSQL example below)
DATABASE_URL=sqlite+aiosqlite:///./data/traveltech.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/traveltech

# Локально без установки Redis:
REDIS_URL=memory://
# С Redis:
# REDIS_URL=redis://localhost:6379/0

# Kiosk PIN codes
KIOSK_PIN_POPOVA=1234
KIOSK_PIN_LOBACHEVSKY=5678
KIOSK_PIN_ROBOT=9012
KIOSK_PIN_RAMEEVA=3456

# Google GenAI (used by ai_services.py)
GEMINI_API_KEY=your_key_here

# Успешные генерации (фото/видео) — append в файл, время MSK
# GENERATION_LOG_PATH=data/generations.log

# --- Frontend (Vite) ---
# Обложки стилей: public/static/{neuro_styles,artists}/ — в dist при сборке, с missioninnopolis.ru
# Телефон для QR на рекламной заставке (tel:+7843...)
# VITE_AGENCY_PHONE=+78431234567
# VITE_AGENCY_PHONE_DISPLAY=+7 (843) 123-45-67
# Локально (npm run dev) не задавайте — прокси Vite: /api → http://127.0.0.1:8000
# Продакшен: API и результаты ИИ (/static/results) — только бэкенд:
# VITE_API_URL=https://traveltech-mgig.onrender.com
# Киоск по умолчанию, если нет ?location= в URL
# VITE_KIOSK_ID=Popova
# Экран киоска: http://localhost:5173/?location=Popova
# ИТ-парк Рамеева: ?location=Rameeva
# Страница гида (в QR): http://localhost:5173/guide/auth?location=Popova
