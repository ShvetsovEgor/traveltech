# =========================
# ОС и Среда разработки
# =========================
# Системные файлы macOS (обязательно!)
.DS_Store
.AppleDouble
.LSOverride
Icon

# Локальные настройки редактора Cursor / VS Code
.vscode/
.cursor/
*.code-workspace

# =========================
# Node.js и Next.js
# =========================
# Зависимости (самая тяжелая папка)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Сборка Next.js
.next/
out/
build/

# =========================
# Python (Для ML и ботов)
# =========================
# Кэш и виртуальные окружения
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# Лог успешных генераций
data/generations.log

# =========================
# Секреты и ключи
# =========================
